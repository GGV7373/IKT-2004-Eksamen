<%- include('layout/header') %>

<div class="auth-page">
  <h1>Logg inn</h1>
  <% if (info) { %><p class="msg-success"><%= info %></p><% } %>
  <% if (error) { %><p class="msg-error"><%= error %></p><% } %>
  <form method="POST" action="/login" class="auth-form">
    <label>E-post<input type="email" name="email" required autofocus></label>
    <label>Passord<input type="password" name="password" required></label>
    <button type="submit">Logg inn</button>
  </form>
  <p>Har du ikke konto? <a href="/register">Registrer deg</a></p>
</div>

<%- include('layout/footer') %>
