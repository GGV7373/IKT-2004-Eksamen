<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <h1>Admin innlogging</h1>
  <% if (error) { %><p class="msg-error"><%= error %></p><% } %>
  <form method="POST" action="/admin/login" class="auth-form">
    <label>Brukernavn<input type="text" name="username" required autofocus></label>
    <label>Passord<input type="password" name="password" required></label>
    <button type="submit">Logg inn</button>
  </form>
  <p><a href="/">Tilbake til butikk</a></p>
</div>
</body>
</html>
