<%- include('header') %>

<div class="admin-section">
  <h1>Bestillinger</h1>
  <table class="admin-table">
    <thead>
      <tr><th>ID</th><th>Kunde</th><th>E-post</th><th>Total</th><th>Status</th><th>Dato</th></tr>
    </thead>
    <tbody>
      <% orders.forEach(o => { %>
      <tr>
        <td>#<%= o.id %></td>
        <td><%= o.full_name %></td>
        <td><%= o.email %></td>
        <td>kr <%= parseFloat(o.total_price).toFixed(2) %></td>
        <td><span class="order-status status-<%= o.status %>"><%= o.status %></span></td>
        <td><%= new Date(o.created_at).toLocaleDateString('no-NO') %></td>
      </tr>
      <% }) %>
      <% if (orders.length === 0) { %>
      <tr><td colspan="6">Ingen bestillinger ennå.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
